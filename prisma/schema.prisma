generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
// ─── SPORT ───────────────────────────────────────────────
model Sport {
  id       String @id @default(uuid())
  name     String @unique   // e.g. "Cricket", "Football"
  format   Format @default(KNOCKOUT)

  teams    Team[]
  matches  Match[]

  createdAt DateTime @default(now())
}

enum Format {
  KNOCKOUT
  ROUND_ROBIN
  GROUP_KNOCKOUT
}

// ─── TEAM ────────────────────────────────────────────────
model Team {
  id         String   @id @default(uuid())
  sportId    String
  sport      Sport    @relation(fields: [sportId], references: [id])
  teamName   String
  department String
  captain    String
  status     TeamStatus @default(PENDING)

  players    Player[]

  teamA_matches Match[] @relation("TeamA")
  teamB_matches Match[] @relation("TeamB")

  createdAt  DateTime @default(now())

  @@unique([sportId, teamName])
}

enum TeamStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── PLAYER ──────────────────────────────────────────────
model Player {
  id        String  @id @default(uuid())
  name      String
  jerseyNo  Int
  teamId    String
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, jerseyNo])
}

// ─── MATCH ───────────────────────────────────────────────
model Match {
  id         String      @id @default(uuid())
  sportId    String
  sport      Sport       @relation(fields: [sportId], references: [id])

  teamAId    String
  teamA      Team        @relation("TeamA", fields: [teamAId], references: [id])

  teamBId    String
  teamB      Team        @relation("TeamB", fields: [teamBId], references: [id])

  date       String
  time       String
  venue      String

  scoreA     Int         @default(0)
  scoreB     Int         @default(0)

  status     MatchStatus @default(UPCOMING)
  round      String?     // e.g. "Quarterfinal", "Group Stage Day 2"
  winnerId   String?     // teamId of winner (null if draw or not played)

  createdAt  DateTime    @default(now())
}

enum MatchStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}